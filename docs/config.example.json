  "codex_sandbox_mode": "workspace-write",
  "model_env": {
    "ANTHROPIC_MODEL": "glm-chat",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "glm-chat",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "glm-chat",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "glm-chat",
    "ANTHROPIC_REASONING_MODEL": "glm-chat"
  },
  "timeout": 300,
  "models": [
    {
      "name": "DeepSeek Pro",
      "model_id": "deepseek-pro",
